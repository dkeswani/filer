{
  "name": "@filer/cli",
  "version": "1.2.1",
  "description": "Filer — the knowledge layer for codebases. Extracts constraints, patterns, dangers, and decisions for AI agents.",
  "type": "module",
  "bin": {
    "filer": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/lib/index.js",
      "types":  "./dist/lib/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm test && npm run build"
  },
  "keywords": [
    "ai",
    "agents",
    "codebase",
    "knowledge",
    "context",
    "llm",
    "claude",
    "mcp"
  ],
  "author": "dkeswani",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dkeswani/filer.git"
  },
  "homepage": "https://github.com/dkeswani/filer#readme",
  "bugs": {
    "url": "https://github.com/dkeswani/filer/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@secretlint/secretlint-rule-preset-recommend": "^12.2.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "glob": "^11.0.0",
    "inquirer": "^12.3.0",
    "open": "^11.0.0",
    "ora": "^8.1.1",
    "p-limit": "^7.3.0",
    "secretlint": "^12.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
