{
  "version": "1.0",
  "llm": {
    "provider": "anthropic",
    "model": "claude-sonnet-4-6",
    "indexing_model": "claude-haiku-4-5-20251001",
    "deep_model": "claude-sonnet-4-6"
  },
  "include": [
    "src/**"
  ],
  "exclude": [
    "**/*.test.ts",
    "**/*.test.js",
    "**/*.spec.ts",
    "**/*.spec.js",
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/__generated__/**",
    "**/.filer/**"
  ],
  "module_boundaries": {
    "strategy": "directory",
    "max_depth": 3,
    "manifests": [
      "package.json",
      "pyproject.toml",
      "go.mod",
      "Cargo.toml"
    ]
  },
  "node_types": {
    "constraint": {
      "enabled": true,
      "min_confidence": 0.8,
      "require_verification": false
    },
    "danger": {
      "enabled": true,
      "min_confidence": 0.8,
      "require_verification": false
    },
    "assumption": {
      "enabled": true,
      "min_confidence": 0.8,
      "require_verification": false
    },
    "pattern": {
      "enabled": true,
      "min_confidence": 0.8,
      "require_verification": false
    },
    "intent": {
      "enabled": true,
      "min_confidence": 0.8,
      "require_verification": false
    },
    "decision": {
      "enabled": true,
      "min_confidence": 0.8,
      "require_verification": false
    },
    "security": {
      "enabled": true,
      "min_confidence": 0.9,
      "require_verification": true
    },
    "antipattern": {
      "enabled": true,
      "min_confidence": 0.8,
      "require_verification": false
    }
  },
  "auto_update": true,
  "stale_threshold": 0.7
}